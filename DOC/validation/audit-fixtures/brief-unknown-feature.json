    "client_brief": {
      "brand_name": "Acme",
      "brand_voice": "modern",
      "logo_url": null,
      "color_seed": null,
      "target_locale": "en-US",
      "target_regions": ["US"],
      "deadline": null,
      "budget_band": "mid"
    },
    "constraints": {
      "deployment_platform": "vercel",
      "database": "postgres",
      "no_auth": false,
      "no_payments": false
    }
